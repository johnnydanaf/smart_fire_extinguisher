{
  "logging": {
    "version": 1,
    "disable_existing_loggers": false,
    "formatters": {
      "standard": {
        "format": "[%(asctime)s] %(name)s [%(levelname)s] %(message)s",
        "datefmt": "%Y-%m-%d %H:%M:%S"
      },
      "detailed": {
        "format": "[%(asctime)s] %(name)s [%(levelname)s] [%(funcName)s:%(lineno)d] %(message)s",
        "datefmt": "%Y-%m-%d %H:%M:%S"
      }
    },
    "handlers": {
      "console": {
        "class": "logging.StreamHandler",
        "level": "DEBUG",
        "formatter": "standard",
        "stream": "ext://sys.stdout"
      },
      "file": {
        "class": "logging.handlers.RotatingFileHandler",
        "level": "DEBUG",
        "formatter": "detailed",
        "filename": "logs/fire_robot.log",
        "maxBytes": 10485760,
        "backupCount": 5
      }
    },
    "root": {
      "level": "DEBUG",
      "handlers": ["console", "file"]
    },
    "loggers": {
      "sense": {"level": "DEBUG"},
      "think": {"level": "DEBUG"},
      "act": {"level": "DEBUG"},
      "see": {"level": "DEBUG"},
      "core": {"level": "DEBUG"}
    }
  },
  "system": {
    "system_mode": "surveillance",
    "polling_interval_idle_ms": 10000,
    "polling_interval_active_ms": 1000,
    "i2c_buses": {
      "primary": { "scl": "SCL", "sda": "SDA" }
    }
  },
  "sensors": {
    "smoke": {
      "enabled": true,
      "interface": "i2c",
      "bus": "primary",
      "device_type": "ads1115",
      "address": "0x48",
      "channel": 0,
      "gain": 1,
      "equation": "A * (((3.3 - (raw / 32767.0) * 3.3) / ((raw / 32767.0) * 3.3)) * RL / Ro) ** B",
      "eq_params": { "RL": 10000, "Ro": 9500, "A": 574.25, "B": -2.222 },
      "raw_min": 0,
      "raw_max": 32767,
      "physical_min": 0,
      "physical_max": 10000,
      "threshold_physical": 300,
      "unit": "ppm",
      "max_retries": 3
    },
    "heat_grid": {
      "enabled": true,
      "interface": "i2c",
      "bus": "primary",
      "device_type": "amg8833",
      "address": "0x69",
      "raw_min": 0,
      "raw_max": 80,
      "physical_min": 0,
      "physical_max": 80,
      "threshold_physical": 50,
      "unit": "C",
      "max_retries": 3
    }
  },
  "think": {
    "active_model": "xgboost",
    "model_weights_path": "model_weights/",
    "max_gap_ms": 500,
    "chain_length": 5,
    "poa_map": {
      "1": "monitor",
      "2": "monitor",
      "3": "alert",
      "4": "suppress",
      "5": "evacuate"
    },
    "label_encoding": {
      "composite_label": {
        "none": 0,
        "smoke": 1,
        "fire": 2,
        "fire_smoke": 3
      },
      "scene_label": {
        "clear": 0,
        "hazy": 1,
        "smoky": 2,
        "fire": 3
      }
    },
    "xgboost": {
      "n_estimators": 100,
      "max_depth": 4,
      "learning_rate": 0.1,
      "subsample": 0.8,
      "colsample_bytree": 0.8
    }
  }
}
                <UserObject label="&quot;actuators&quot;: {&#xa;&amp;nbsp; &quot;arm&quot;: {&#xa;&amp;nbsp; &amp;nbsp; &quot;enabled&quot;: true,&#xa;&amp;nbsp; &amp;nbsp; &quot;dof&quot;: 2,&#xa;&amp;nbsp; &amp;nbsp; &quot;segments&quot;: [&#xa;&amp;nbsp; &amp;nbsp; &amp;nbsp; {&#xa;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &quot;id&quot;: 0,&#xa;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &quot;alpha&quot;: 0.0,&#xa;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &quot;a&quot;: 0.25,&#xa;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &quot;d&quot;: 0.0,&#xa;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &quot;theta_min&quot;: -90.0,&#xa;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &quot;theta_max&quot;: 90.0&#xa;&amp;nbsp; &amp;nbsp; &amp;nbsp; },&#xa;&amp;nbsp; &amp;nbsp; &amp;nbsp; {&#xa;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &quot;id&quot;: 1,&#xa;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &quot;alpha&quot;: 0.0,&#xa;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &quot;a&quot;: 0.18,&#xa;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &quot;d&quot;: 0.0,&#xa;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &quot;theta_min&quot;: -120.0,&#xa;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &quot;theta_max&quot;: 120.0&#xa;&amp;nbsp; &amp;nbsp; &amp;nbsp; }&#xa;&amp;nbsp; &amp;nbsp; ],&#xa;&amp;nbsp; &amp;nbsp; &quot;heat_matrix_offset&quot;: [0.0, 0.0, 0.02],&#xa;&amp;nbsp; &amp;nbsp; &quot;camera_offset&quot;: [0.0, 0.01, 0.02],&#xa;&amp;nbsp; &amp;nbsp; &quot;pump_offset&quot;: [0.0, 0.0, 0.03]&#xa;&amp;nbsp; },&#xa;&amp;nbsp; &quot;pump&quot;: {&#xa;&amp;nbsp; &amp;nbsp; &quot;enabled&quot;: true,&#xa;&amp;nbsp; &amp;nbsp; &quot;pin&quot;: 18,&#xa;&amp;nbsp; &amp;nbsp; &quot;max_duration_s&quot;: 30&#xa;&amp;nbsp; },&#xa;&amp;nbsp; &quot;alarm&quot;: {&#xa;&amp;nbsp; &amp;nbsp; &quot;enabled&quot;: true,&#xa;&amp;nbsp; &amp;nbsp; &quot;pin&quot;: 24,&#xa;&amp;nbsp; &amp;nbsp; &quot;duration_s&quot;: 10&#xa;&amp;nbsp; }&#xa;},&#xa;&quot;act&quot;: {&#xa;&amp;nbsp; &quot;default_
                <UserObject label="&lt;span&gt;  activate() → None&#xa;&lt;/span&gt;&lt;span&gt;    ← starts tracking loop&#xa;&lt;/span&gt;&lt;span&gt;  deactivate() → None&#xa;&lt;/span&gt;&lt;span&gt;    ← stops tracking loop, returns arm to home position&#xa;&lt;/span&gt;&lt;span&gt;  is_healthy() → bool&#xa;&lt;/span&gt;&lt;span&gt;    ← checks servo responses&#xa;&lt;/span&gt;&lt;span&gt;  aim(target: Tuple[float,float]) → None&#xa;&lt;/span&gt;&lt;span&gt;    ← calls _solver.solve(target)&#xa;&lt;/span&gt;&lt;span&gt;    ← moves servos to resulting angles&#xa;&lt;/span&gt;&lt;span&gt;  lock() → None&#xa;&lt;/span&gt;&lt;span&gt;    ← freezes arm on current target during suppression&#xa;&lt;/span&gt;&lt;span&gt;  unlock() → None&#xa;&lt;/span&gt;&lt;span&gt;    ← resumes tracking after suppression&#xa;&lt;/span&gt;&lt;span&gt;  _tracking_loop() → None&#xa;&lt;/span&gt;&lt;span&gt;    ← reads state.heat_matrix_hotspot&#xa;&lt;/span&gt;&lt;span&gt;    ← if not _locked → calls aim()&#xa;&lt;/span&gt;&lt;span&gt;    ← runs continuously while active&#xa;&lt;/span&gt;&lt;span&gt;  _move_to(angles: List[float]) → None&#xa;&lt;/span&gt;&lt;span&gt;    ← sends angle commands to servos&#xa;&lt;/span&gt;&lt;span&gt;  run_process() → None&#xa;&lt;/span&gt;&lt;span&gt;    ← starts _tracking_loop in its process&#xa;&lt;/span&gt;" link="&lt;span&gt;  activate() → None&#xa;&lt;/span&gt;&lt;span&gt;    ← starts tracking loop&#xa;&lt;/span&gt;&lt;span&gt;  deactivate() → None&#xa;&lt;/span&gt;&lt;span&gt;    ← stops tracking loop, returns arm to home position&#xa;&lt;/span&gt;&lt;span&gt;  is_healthy() → bool&#xa;&lt;/span&gt;&lt;span&gt;    ← checks servo responses&#xa;&lt;/span&gt;&lt;span&gt;  aim(target: Tuple[float,float]) → None&#xa;&lt;/span&gt;&lt;span&gt;    ← calls _solver.solve(target)&#xa;&lt;/span&gt;&lt;span&gt;    ← moves servos to resulting angles&#xa;&lt;/span&gt;&lt;span&gt;  lock() → None&#xa;&lt;/span&gt;&lt;span&gt;    ← freezes arm on current target during suppression&#xa;&lt;/span&gt;&lt;span&gt;  unlock() → None&#xa;&lt;/span&gt;&lt;span&gt;    ← resumes tracking after suppression&#xa;&lt;/span&gt;&lt;span&gt;  _tracking_loop() → None&#xa;&lt;/span&gt;&lt;span&gt;    ← reads state.heat_matrix_hotspot&#xa;&lt;/span&gt;&lt;span&gt;    ← if not _locked → calls aim()&#xa;&lt;/span&gt;&lt;span&gt;    ← runs continuously while active&#xa;&lt;/span&gt;&lt;span&gt;  _move_to(angles: List[float]) → None&#xa;&lt;/span&gt;&lt;span&gt;    ← sends angle commands to servos&#xa;&lt;/span&gt;&lt;span&gt;  run_process() → None&#xa;&lt;/span&gt;&lt;span&gt;    ← starts _tracking_loop in its process&#xa;&lt;/span&gt;" id="29">

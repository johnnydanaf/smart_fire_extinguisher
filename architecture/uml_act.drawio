                </mxCell>
                <UserObject label="&lt;span&gt;  __init__(config_path: str,&#xa;&lt;/span&gt;&lt;span&gt;           state: SystemState,&#xa;&lt;/span&gt;&lt;span&gt;           db: ThinkDatabase,&#xa;&lt;/span&gt;&lt;span&gt;           notifier: NotificationService) → None&#xa;&lt;/span&gt;&lt;span&gt;    ← calls ActuatorParser.load()&#xa;&lt;/span&gt;&lt;span&gt;    ← builds initial mode from config default_mode&#xa;&lt;/span&gt;&lt;span&gt;  start() → None&#xa;&lt;/span&gt;&lt;span&gt;    ← starts each actuator as its own Process&#xa;&lt;/span&gt;&lt;span&gt;    ← starts _act_loop&#xa;&lt;/span&gt;&lt;span&gt;  stop() → None&#xa;&lt;/span&gt;&lt;span&gt;    ← stops all processes gracefully&#xa;&lt;/span&gt;&lt;span&gt;  set_mode(mode: ActMode) → None&#xa;&lt;/span&gt;&lt;span&gt;    ← swaps mode at runtime&#xa;&lt;/span&gt;&lt;span&gt;    ← called by SystemOrchestrator from website&#xa;&lt;/span&gt;&lt;span&gt;  _act_loop() → None&#xa;&lt;/span&gt;&lt;span&gt;    ← watches state.danger_level&#xa;&lt;/span&gt;&lt;span&gt;    ← if danger_level &amp;gt;= threshold → calls _mode.run()&#xa;&lt;/span&gt;&lt;span&gt;    ← if danger_level &amp;lt; threshold for clear_delay_s&#xa;&lt;/span&gt;&lt;span&gt;       → deactivates pump + alarm&#xa;&lt;/span&gt;&lt;span&gt;  _should_run() → bool&#xa;&lt;/span&gt;&lt;span&gt;    ← reads state.sensor_triggered&#xa;&lt;/span&gt;&lt;span&gt;    ← returns True if system should be active&#xa;&lt;/span&gt;" link="&lt;span&gt;  __init__(config_path: str,&#xa;&lt;/span&gt;&lt;span&gt;           state: SystemState,&#xa;&lt;/span&gt;&lt;span&gt;           db: ThinkDatabase,&#xa;&lt;/span&gt;&lt;span&gt;           notifier: NotificationService) → None&#xa;&lt;/span&gt;&lt;span&gt;    ← calls ActuatorParser.load()&#xa;&lt;/span&gt;&lt;span&gt;    ← builds initial mode from config default_mode&#xa;&lt;/span&gt;&lt;span&gt;  start() → None&#xa;&lt;/span&gt;&lt;span&gt;    ← starts each actuator as its own Process&#xa;&lt;/span&gt;&lt;span&gt;    ← starts _act_loop&#xa;&lt;/span&gt;&lt;span&gt;  stop() → None&#xa;&lt;/span&gt;&lt;span&gt;    ← stops all processes gracefully&#xa;&lt;/span&gt;&lt;span&gt;  set_mode(mode: ActMode) → None&#xa;&lt;/span&gt;&lt;span&gt;    ← swaps mode at runtime&#xa;&lt;/span&gt;&lt;span&gt;    ← called by SystemOrchestrator from website&#xa;&lt;/span&gt;&lt;span&gt;  _act_loop() → None&#xa;&lt;/span&gt;&lt;span&gt;    ← watches state.danger_level&#xa;&lt;/span&gt;&lt;span&gt;    ← if danger_level &amp;gt;= threshold → calls _mode.run()&#xa;&lt;/span&gt;&lt;span&gt;    ← if danger_level &amp;lt; threshold for clear_delay_s&#xa;&lt;/span&gt;&lt;span&gt;       → deactivates pump + alarm&#xa;&lt;/span&gt;&lt;span&gt;  _should_run() → bool&#xa;&lt;/span&gt;&lt;span&gt;    ← reads state.sensor_triggered&#xa;&lt;/span&gt;&lt;span&gt;    ← returns True if system should be active&#xa;&lt;/span&gt;" id="10">
                    <mxCell style="text;strokeColor=#666666;fillColor=#f5f5f5;align=left;verticalAlign=middle;spacingLeft=4;spacingRight=4;overflow=hidden;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;rotatable=0;whiteSpace=wrap;html=1;fontColor=#333333;fontSize=16;" vertex="1" parent="8">

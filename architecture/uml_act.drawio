                <UserObject label="&lt;span&gt;  run(snapshot, actuators, notifier) → None&#xa;&lt;/span&gt;&lt;span&gt;    ← shows model prediction on website&#xa;&lt;/span&gt;&lt;span&gt;      (danger_level, recommended_action, model_accuracy)&#xa;&lt;/span&gt;&lt;span&gt;    ← waits for human feedback&#xa;&lt;/span&gt;&lt;span&gt;    ← writes true_danger_level + true_action to DB row&#xa;&lt;/span&gt;&lt;span&gt;    ← sets validated = True on that row&#xa;&lt;/span&gt;&lt;span&gt;    ← updates model_accuracy&#xa;&lt;/span&gt;&lt;span&gt;    ← optionally allows fire to escalate naturally&#xa;&lt;/span&gt;&lt;span&gt;      so model learns from growth rate effect&#xa;&lt;/span&gt;" link="&lt;div class=&quot;relative group/copy bg-bg-000/50 border-0.5 border-border-400 rounded-lg focus:outline-none focus-visible:ring-2 focus-visible:ring-accent-100&quot; tabindex=&quot;0&quot; aria-label=&quot;python code&quot; role=&quot;group&quot;&gt;&lt;div class=&quot;overflow-x-auto&quot;&gt;&lt;pre style=&quot;color: rgb(234, 236, 240); background: transparent; font-family: var(--font-mono);&quot; class=&quot;code-block__code !my-0 !rounded-lg !text-sm !leading-relaxed p-3.5&quot;&gt;&lt;code style=&quot;color: rgb(234, 236, 240); background: transparent; font-family: var(--font-mono); white-space: pre;&quot; class=&quot;language-python&quot;&gt;&lt;span&gt;&lt;span&gt;    &lt;/span&gt;&lt;span style=&quot;color: rgb(211, 215, 222);&quot; class=&quot;token token decorator annotation&quot;&gt;@abstractmethod&lt;/span&gt;&lt;span&gt;&#xa;&lt;/span&gt;&lt;/span&gt;&lt;span&gt;&lt;span&gt;    &lt;/span&gt;&lt;span style=&quot;color: rgb(204, 123, 244);&quot; class=&quot;token token&quot;&gt;def&lt;/span&gt;&lt;span&gt; &lt;/span&gt;&lt;span style=&quot;color: rgb(112, 184, 255);&quot; class=&quot;token token&quot;&gt;infer&lt;/span&gt;&lt;span style=&quot;color: rgb(211, 215, 222);&quot; class=&quot;token token&quot;&gt;(&lt;/span&gt;&lt;span&gt;self&lt;/span&gt;&lt;span style=&quot;color: rgb(211, 215, 222);&quot; class=&quot;token token&quot;&gt;,&lt;/span&gt;&lt;span&gt; frame&lt;/span&gt;&lt;span style=&quot;color: rgb(211, 215, 222);&quot; class=&quot;token token&quot;&gt;:&lt;/span&gt;&lt;span&gt; np&lt;/span&gt;&lt;span style=&quot;color: rgb(211, 215, 222);&quot; class=&quot;token token&quot;&gt;.&lt;/span&gt;&lt;span&gt;ndarray&lt;/span&gt;&lt;span style=&quot;color: rgb(211, 215, 222);&quot; class=&quot;token token&quot;&gt;)&lt;/span&gt;&lt;span&gt; &lt;/span&gt;&lt;span style=&quot;color: rgb(234, 236, 240);&quot; class=&quot;token token&quot;&gt;-&lt;/span&gt;&lt;span style=&quot;color: rgb(234, 236, 240);&quot; class=&quot;token token&quot;&gt;&amp;gt;&lt;/span&gt;&lt;span&gt; List&lt;/span&gt;&lt;span style=&quot;color: rgb(211, 215, 222);&quot; class=&quot;token token&quot;&gt;[&lt;/span&gt;&lt;span&gt;Detection&lt;/span&gt;&lt;span style=&quot;color: rgb(211, 215, 222);&quot; class=&quot;token token&quot;&gt;]&lt;/span&gt;&lt;span&gt;&#xa;&lt;/span&gt;&lt;/span&gt;&lt;span&gt;&lt;span&gt;    &lt;/span&gt;&lt;span style=&quot;color: rgb(204, 123, 244);&quot; class=&quot;token token&quot;&gt;def&lt;/span&gt;&lt;span&gt; &lt;/span&gt;&lt;span style=&quot;color: rgb(112, 184, 255);&quot; class=&quot;token token&quot;&gt;load&lt;/span&gt;&lt;span style=&quot;color: rgb(211, 215, 222);&quot; class=&quot;token token&quot;&gt;(&lt;/span&gt;&lt;span style=&quot;color: rgb(211, 215, 222);&quot; class=&quot;token token&quot;&gt;)&lt;/span&gt;&lt;span&gt; &lt;/span&gt;&lt;span style=&quot;color: rgb(234, 236, 240);&quot; class=&quot;token token&quot;&gt;-&lt;/span&gt;&lt;span style=&quot;color: rgb(234, 236, 240);&quot; class=&quot;token token&quot;&gt;&amp;gt;&lt;/span&gt;&lt;span&gt; &lt;/span&gt;&lt;span style=&quot;color: rgb(94, 237, 237);&quot; class=&quot;token token&quot;&gt;None&lt;/span&gt;&lt;/span&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&#xa;&lt;div class=&quot;relative group/copy bg-bg-000/50 border-0.5 border-b